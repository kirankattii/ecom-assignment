                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number"
                },
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Number of items per page"
                },
                {
                  "key": "sort",
                  "value": "newest",
                  "description": "Sort option: newest, price_asc, price_desc, name_asc, name_desc"
                }
              ]
            },
            "description": "Retrieve all active products with optional search, category filters, pagination, and sorting."
